# The Moon Records OS — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# ── CDN / SFTP ────────────────────────────────────────────────────────────────
CDN_HOST=cdn.the-moon-records.de
CDN_PROTOCOL=ftp
CDN_PORT=21
CDN_USER=
CDN_PASSWORD=
CDN_KEY_PATH=
CDN_BASE_PATH=/releases

# ── CDN Public URL ────────────────────────────────────────────────────────────
CDN_PUBLIC_URL=https://cdn.the-moon-records.de
